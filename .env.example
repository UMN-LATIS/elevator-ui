BASE_ORIGIN="/api" # /api for local dev with proxy
VITE_BASE_ORIGIN="${BASE_ORIGIN}"

# where `/api` is proxied to

# DEV ELEVATOR
# VITE_API_PROXY_TARGET="https://dev.elevator.umn.edu"
# BASE_PATH="/defaultinstance"

# LOCAL ELEVATOR
# VITE_API_PROXY_TARGET="https://localhost"
# BASE_PATH="/defaultinstance"

# MOCK SERVER
VITE_API_PROXY_TARGET="http://localhost:3001"
BASE_PATH="/defaultinstance"

VITE_BASE_PATH="${BASE_PATH}"
BASE_URL="${BASE_ORIGIN}${BASE_PATH}"
VITE_BASE_URL="${BASE_URL}"

ARCGIS_API_KEY="YOUR_ARCGIS_API_KEY"
VITE_ARCGIS_API_KEY="${ARCGIS_API_KEY}"

VITE_GOOGLE_ANALYTICS_ID="YOUR_GOOGLE_ANALYTICS_ID"
VITE_AUTOLOAD_MAX_SEARCH_RESULTS=false
